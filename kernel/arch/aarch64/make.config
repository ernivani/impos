# aarch64 kernel architecture configuration
#
# Phase 0: Minimal boot stub — just enough to compile and link.
# Portable code (fs, net, crypto, gui, app) will be added incrementally
# as each phase stabilizes (Phases 2-8).

KERNEL_ARCH_CFLAGS=-march=armv8-a -mgeneral-regs-only \
	-Wno-unused-parameter -Wno-sign-compare -Wno-missing-field-initializers \
	-Wno-pointer-sign
KERNEL_ARCH_CPPFLAGS=
KERNEL_ARCH_LDFLAGS=-z max-page-size=4096
KERNEL_ARCH_LIBS=

# Use aarch64-specific stub kernel_main instead of the full i386 kernel.c
KERNEL_MAIN_OBJ=$(ARCHDIR)/kernel_main.o

# Phase 0-1: Minimal boot stubs only
KERNEL_ARCH_OBJS=\
$(ARCHDIR)/boot.o \
$(ARCHDIR)/tty.o \
